#!/bin/sh
# =============================================================
# Author:  gh0stzk
# Repo:    https://github.com/gh0stzk/dotfiles
# Date:    24.04.2025
#
# AnimateWall - Animated Wallpaper for BSPWM
# Info:  Script to set animated backgrounds using
#        xwinwrap and mpv. Supports automatic aspect ratio adjustment.
#
# Copyright (C) 2021-2025 gh0stzk <z0mbi3.zk@protonmail.com>
# Licensed under GPL-3.0 license
# =============================================================

#!/bin/bash

start() {
    video_path="$1"

    case "$video_path" in
        *.mp4|*.mkv|*.gif|*.mov|*.webm) ;;
        *)
            echo "[-] The file does not have a valid video extension"
            exit 1
        ;;
    esac

    # Obtenemos las pantallas
    SCREENS=$(xrandr | grep -Eo '[0-9]+x[0-9]+\+[0-9]+\+[0-9]+')

    for geometry in $SCREENS; do
        # Lanzamos xwinwrap
        # Eliminamos --video-aspect-override para evitar el estiramiento
        # Usamos --video-unscaled=no para permitir que mpv lo ajuste al tamaño de xwinwrap
        xwinwrap -g "$geometry" -un -fdt -ni -b -nf \
            -- mpv --hwdec=auto -vo x11 --no-audio --no-border --no-config \
            --no-window-dragging --no-input-default-bindings --no-osd-bar \
            --no-sub --loop -wid WID \
            --keepaspect=yes \
            --video-unscaled=no \
            --panscan=0 \
            "$video_path" > /dev/null 2>&1 &
            
        # NOTA SOBRE PANSCAN:
        # --panscan=0 -> Mantiene el video íntegro con barras negras (Letterbox).
        # --panscan=1 -> Hace zoom hasta llenar la pantalla (recorta bordes pero no estira).
    done
}

stop() {
    killall xwinwrap > /dev/null 2>&1
}

print_help() {
    echo "Usage: AnimatedWall [--start] [--stop] video_path"
    echo "    --start    Start playback of video file."
    echo "    --stop     Stop active playback."
}

if [ "$#" -eq 0 ]; then
    print_help
    exit 1
fi

while [ "$#" -gt 0 ]; do
    case $1 in
        --start)
            shift
            start "$1"
            shift
            ;;
        --stop)
            stop
            shift
            ;;
        *)
            echo "Unknown parameter: $1"
            exit 1
            ;;
    esac
done
