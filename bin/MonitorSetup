#!/bin/sh

# Obtener estado actual
XRANDR_OUTPUT=$(xrandr)

# Apagar monitores desconectados
echo "$XRANDR_OUTPUT" | awk '/disconnected/ {print $1}' | while read -r mon; do
    xrandr --output "$mon" --off
done

# Verificar si HDMI-1 está conectado
HDMI_CONNECTED=$(echo "$XRANDR_OUTPUT" | grep "^HDMI-1 connected")

# Verificar si eDP-1 está conectado
EDP_CONNECTED=$(echo "$XRANDR_OUTPUT" | grep "^eDP-1 connected")

# Configuración
if [ -n "$EDP_CONNECTED" ] && [ -n "$HDMI_CONNECTED" ]; then
    # Laptop + monitor externo
    xrandr --output eDP-1 --primary --mode 1920x1080 --pos 0x0 \
           --output HDMI-1 --mode 1920x1080 --rate 59.89 --right-of eDP-1

    bspc monitor eDP-1 -d 1 2 3 4
    bspc monitor HDMI-1 -d 5 6 7 8
    bspc wm -O eDP-1 HDMI-1

elif [ -n "$EDP_CONNECTED" ]; then
    # Solo laptop
    xrandr --output eDP-1 --primary --mode 1920x1080 --pos 0x0

    bspc monitor eDP-1 -d 1 2 3 4 5 6

elif [ -n "$HDMI_CONNECTED" ]; then
    # Solo monitor externo
    xrandr --output HDMI-1 --primary --mode 1920x1080 --rate 59.89 --pos 0x0

    bspc monitor HDMI-1 -d 1 2 3 4 5 6

else
    echo "No se detectaron monitores activos"
fi
